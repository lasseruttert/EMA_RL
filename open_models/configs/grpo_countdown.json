{
    "model": "unsloth/Qwen3-14B-unsloth-bnb-4bit",
    "training_file": "../data/countdown_train.jsonl",
    "finetuned_model_id": "grpo/model",
    "output_dir": "./tmp/grpo_countdown_baseline",
    "loss": "grpo",
    "grader_type": "countdown",
    "reward_model": "gpt-4.1-mini",
    "max_seq_length": 2048,
    "max_prompt_length": 512,
    "rl_max_new_tokens": 2048,
    "user_prompt_suffix": "\n\nClose your </think> tag, then write your equation inside <answer> </answer> tags. Example: <answer> (1 + 2) * 3 - 4 </answer>",
    "beta": 0,
    "epochs": 1,
    "num_generations": 4,
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "learning_rate": 5e-6,
    "rl_temperature": 0.8,
    "rl_top_p": 0.9,
    "evaluate_epoch": 1,
    "load_in_4bit": true,
    "r": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "use_rslora": true,
    "lora_bias": "none",
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
    "logging_steps": 5,
    "optim": "adamw_8bit",
    "weight_decay": 0.1,
    "lr_scheduler_type": "cosine",
    "seed": 3407,
    "print_training": false
}
