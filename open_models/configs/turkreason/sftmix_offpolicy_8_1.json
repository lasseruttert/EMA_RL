{
    "model": "unsloth/Qwen3-14B-unsloth-bnb-4bit",
    "training_file": "../data/turkreason_train.jsonl",
    "finetuned_model_id": "grpo/model",
    "output_dir": "./tmp/grpo_turkreason_sftmix_offpolicy_8_1",
    "loss": "grposftmix",
    "grader_type": "turkreason",
    "reward_model": "gpt-4.1-mini",
    "max_seq_length": 4096,
    "max_prompt_length": 512,
    "rl_max_new_tokens": 3072,
    "user_prompt_suffix": "\n\nClose your </think> tag, then write the letter of the correct answer (A, B, C, D, or E).",
    "beta": 0,
    "sft_file": "../data/wildguard.jsonl",
    "sft_mix_ratio": 8,
    "sft_loss_weight": 1.0,
    "epochs": 0.5,
    "num_generations": 4,
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "learning_rate": 5e-6,
    "rl_temperature": 0.8,
    "rl_top_p": 0.9,
    "evaluate_epoch": 1,
    "load_in_4bit": true,
    "r": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "use_rslora": true,
    "lora_bias": "none",
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
    "logging_steps": 5,
    "optim": "adamw_8bit",
    "weight_decay": 0.1,
    "lr_scheduler_type": "cosine",
    "seed": 3407,
    "print_training": false
}
