{
    "model": "unsloth/Qwen3-14B-unsloth-bnb-4bit",
    "training_file": "../data/grpo/medmcqa_750_train.jsonl",
    "finetuned_model_id": "grpo/model",
    "max_seq_length": 8192,
    "load_in_4bit": true,
    "loss": "grpo",
    "target_modules": [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj",
        "gate_proj",
        "up_proj",
        "down_proj"
    ],
    "lora_bias": "none",
    "r": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "use_rslora": true,
    "epochs": 1,
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "learning_rate": 5e-06,
    "logging_steps": 1,
    "optim": "adamw_8bit",
    "weight_decay": 0.1,
    "lr_scheduler_type": "cosine",
    "seed": 42,
    "beta": 0,
    "max_grad_norm": 3.0,
    "report_to": "tensorboard",
    "tensorboard_run_name": "grpo_medmcqa_baseline",
    "output_dir": "./tmp/grpo_medmcqa_baseline",
    "reward_model": "gpt-4.1-mini",
    "grader_type": "medmcqa",
    "print_training": true,
    "evaluate_epoch": 1,
    "num_generations": 4,
    "rl_max_new_tokens": 4096,
    "max_prompt_length": 1024,
    "rl_temperature": 0.8,
    "rl_top_p": 0.9,
    "save_strategy": "steps",
    "save_steps": 10,
    "save_total_limit": 2
}
